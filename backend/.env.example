NODE_ENV=development
PORT=8011

# Database (local dev — Docker overrides DATABASE_URL to use postgres service name)
DB_HOST=52.66.166.35
DB_PORT=5433
DB_USERNAME=trovera
DB_PASSWORD=trovera
DB_NAME=trovera_db
DATABASE_URL=postgresql://trovera:trovera@52.66.166.35:5433/trovera_db

# Redis
REDIS_URL=redis://52.66.166.35:6380/0

# Session
SESSION_SECRET=changeme-at-least-32-chars-long-secret
SESSION_MAX_AGE_DAYS=7

# Database Pool
DB_POOL_SIZE=5

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@trovera.app
# SMTP_FROM_NAME=Trovera Library
# SMTP_TLS=false

# CORS
CORS_ORIGINS=http://localhost:3011,http://localhost:3002

# Frontend
FRONTEND_URL=http://localhost:3011

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
# RATE_LIMIT_PER_MINUTE=60
# AUTH_RATE_LIMIT_PER_MINUTE=5

# Translation
# LIBRE_TRANSLATE_URL=
# DEEPLX_URL=
