NODE_ENV=development
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=trovera
DB_PASSWORD=trovera
DB_NAME=trovera_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=changeme-at-least-32-chars-long-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@trovera.app
SMTP_FROM_NAME=Trovera Library
SMTP_TLS=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Frontend
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=5

# Translation
LIBRE_TRANSLATE_URL=
DEEPLX_URL=
